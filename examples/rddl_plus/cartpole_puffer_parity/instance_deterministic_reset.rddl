non-fluents cartpole_puffer_disc_nf {
    domain = cartpole_puffer_discrete;
}

instance inst_cartpole_puffer_disc_det_reset {
    domain = cartpole_puffer_discrete;
    non-fluents = cartpole_puffer_disc_nf;

    init-state {
        pos = 0.0;
        vel = 0.0;
        ang-pos = 0.0;
        ang-vel = 0.0;
    };

    max-nondef-actions = pos-inf;
    horizon = 200;
    discount = 1.0;
}
