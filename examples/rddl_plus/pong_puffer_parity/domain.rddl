//% puffer_config.vec.total_agents = 1024
//% puffer_config.vec.num_buffers = 1
//% puffer_config.vec.num_threads = 16
//% puffer_config.policy.hidden_size = 32
//% puffer_config.policy.num_layers = 1
//% puffer_config.train.gpus = 1
//% puffer_config.train.seed = 42
//% puffer_config.train.total_timesteps = 5000000
//% puffer_config.train.learning_rate = 0.1
//% puffer_config.train.anneal_lr = 1
//% puffer_config.train.min_lr_ratio = 0
//% puffer_config.train.gamma = 0.934713
//% puffer_config.train.gae_lambda = 0.991989
//% puffer_config.train.replay_ratio = 3.05148
//% puffer_config.train.clip_coef = 0.822764
//% puffer_config.train.vf_coef = 5
//% puffer_config.train.vf_clip_coef = 4.95789
//% puffer_config.train.max_grad_norm = 0.752747
//% puffer_config.train.ent_coef = 0.000402915
//% puffer_config.train.beta1 = 0.5
//% puffer_config.train.beta2 = 0.947709
//% puffer_config.train.eps = 0.0001
//% puffer_config.train.minibatch_size = 32768
//% puffer_config.train.horizon = 32
//% puffer_config.train.vtrace_rho_clip = 4.87841
//% puffer_config.train.vtrace_c_clip = 1.48608
//% puffer_config.train.prio_alpha = 0.242089
//% puffer_config.train.prio_beta0 = 0.807575
//% puffer_config.sweep.method = "Protein"
//% puffer_config.sweep.metric = "episode_return"
//% puffer_config.sweep.use_gpu = false
//% runtime_semantics.reset_tick_on = "$reward_nonzero"
//% puffer_logging.score_mode = "episode_return"
//% puffer_logging.perf_mode = "state_ratio"
//% puffer_logging.perf_numerator_state = "score-r"
//% puffer_logging.perf_denominator_states = "score-l, score-r"
domain pong_puffer_parity {

    requirements = {
        reward-deterministic,
        partially-observed
    };

    pvariables {
        WIDTH : { non-fluent, real, default = 500.0 };
        HEIGHT : { non-fluent, real, default = 640.0 };
        PADDLE-WIDTH : { non-fluent, real, default = 20.0 };
        PADDLE-HEIGHT : { non-fluent, real, default = 70.0 };
        BALL-WIDTH : { non-fluent, real, default = 32.0 };
        BALL-HEIGHT : { non-fluent, real, default = 32.0 };
        PADDLE-SPEED : { non-fluent, real, default = 8.0 };
        BALL-INITIAL-SPEED-X : { non-fluent, real, default = 10.0 };
        BALL-INITIAL-SPEED-Y : { non-fluent, real, default = 1.0 };
        BALL-MAX-SPEED-Y : { non-fluent, real, default = 13.0 };
        BALL-SPEED-Y-INCREMENT : { non-fluent, real, default = 3.0 };
        MAX-SCORE : { non-fluent, int, default = 21 };

        min-paddle-y : { interm-fluent, real, level = 1 };
        max-paddle-y : { interm-fluent, real, level = 1 };
        reset-paddle-y : { interm-fluent, real, level = 1 };
        reset-ball-x : { interm-fluent, real, level = 1 };
        reset-ball-y : { interm-fluent, real, level = 1 };
        paddle-dir : { interm-fluent, real, level = 1 };

        paddle-yl : { state-fluent, real, default = 8.0 };
        paddle-yr : { state-fluent, real, default = 8.0 };
        ball-x : { state-fluent, real, default = 4.0 };
        ball-y : { state-fluent, real, default = 9.5 };
        ball-vx : { state-fluent, real, default = 0.6 };
        ball-vy : { state-fluent, real, default = 0.2 };
        score-l : { state-fluent, int, default = 0 };
        score-r : { state-fluent, int, default = 0 };

        move : { action-fluent, int, default = 0 };

        obs-paddle-yl : { observ-fluent, real, default = 0.5 };
        obs-paddle-yr : { observ-fluent, real, default = 0.5 };
        obs-ball-x : { observ-fluent, real, default = 0.2 };
        obs-ball-y : { observ-fluent, real, default = 0.475 };
        obs-ball-vx : { observ-fluent, real, default = 1.0 };
        obs-ball-vy : { observ-fluent, real, default = 0.53846154 };
        obs-score-l : { observ-fluent, real, default = 0.0 };
        obs-score-r : { observ-fluent, real, default = 0.0 };
        s1-active : { interm-fluent, bool, level = 2 };
        s1-opp-delta-raw : { interm-fluent, real, level = 2 };
        s1-opp-delta : { interm-fluent, real, level = 2 };
        s1-paddle-yr-pre : { interm-fluent, real, level = 2 };
        s1-paddle-yl-pre : { interm-fluent, real, level = 2 };
        s1-paddle-yr-clipped : { interm-fluent, real, level = 2 };
        s1-paddle-yl-clipped : { interm-fluent, real, level = 2 };
        s1-ball-x-moved : { interm-fluent, real, level = 2 };
        s1-ball-y-moved : { interm-fluent, real, level = 2 };
        s1-top-bottom-bounce : { interm-fluent, bool, level = 2 };
        s1-ball-vy-wall : { interm-fluent, real, level = 2 };
        s1-left-hit : { interm-fluent, bool, level = 2 };
        s1-left-score : { interm-fluent, bool, level = 2 };
        s1-right-region : { interm-fluent, bool, level = 2 };
