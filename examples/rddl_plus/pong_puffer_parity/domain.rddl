        s1-ball-vx-next : { interm-fluent, real, level = 2 };
        s1-ball-vy-preclamp : { interm-fluent, real, level = 2 };
        s1-ball-vy-next : { interm-fluent, real, level = 2 };
        s1-ball-x-next : { interm-fluent, real, level = 2 };
