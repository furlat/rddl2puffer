    cpfs {
        min-paddle-y = -PADDLE-HEIGHT / 2.0;
        max-paddle-y = HEIGHT - PADDLE-HEIGHT / 2.0;
        reset-paddle-y = HEIGHT / 2.0 - PADDLE-HEIGHT / 2.0;
        reset-ball-x = WIDTH / 5.0;
        reset-ball-y = HEIGHT / 2.0 - BALL-HEIGHT / 2.0;
        paddle-dir = if (move == 1) then 1.0 else if (move == 2) then -1.0 else 0.0;

        s1-active = ~false;
        s1-opp-delta-raw = ball-y - (paddle-yl + PADDLE-HEIGHT / 2.0);
        s1-opp-delta = max[min[s1-opp-delta-raw, PADDLE-SPEED], -PADDLE-SPEED];
        s1-paddle-yr-pre = if (s1-active) then (paddle-yr + PADDLE-SPEED * paddle-dir) else paddle-yr;
        s1-paddle-yl-pre = if (s1-active) then (paddle-yl + s1-opp-delta) else paddle-yl;
        s1-paddle-yr-clipped = max[min[s1-paddle-yr-pre, max-paddle-y], min-paddle-y];
        s1-paddle-yl-clipped = max[min[s1-paddle-yl-pre, max-paddle-y], min-paddle-y];
        s1-ball-x-moved = if (s1-active) then (ball-x + ball-vx) else ball-x;
        s1-ball-y-moved = if (s1-active) then (ball-y + ball-vy) else ball-y;
