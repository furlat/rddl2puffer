        s6-point = s5-point | s6-left-score | s6-right-score;
        s6-score-l = if (s5-point) then s5-score-l else if (s6-right-score) then (s5-score-l + 1) else s5-score-l;
        s6-score-r = if (s5-point) then s5-score-r else if (s6-left-score) then (s5-score-r + 1) else s5-score-r;
        s6-match-terminal = (s6-score-l == MAX-SCORE) | (s6-score-r == MAX-SCORE);
        s6-ball-vx-next = if (s6-left-hit | s6-right-hit) then -s5-ball-vx else s5-ball-vx;
        s6-ball-vy-preclamp = if (s6-right-hit) then (s6-ball-vy-wall + BALL-SPEED-Y-INCREMENT * paddle-dir) else s6-ball-vy-wall;
        s6-ball-vy-next = if (s6-right-hit) then (if (abs[s6-ball-vy-preclamp] < 0.01) then BALL-SPEED-Y-INCREMENT else max[min[s6-ball-vy-preclamp, BALL-MAX-SPEED-Y], -BALL-MAX-SPEED-Y]) else s6-ball-vy-preclamp;
        s6-ball-x-next = if (s6-right-hit) then max[min[s6-ball-x-moved, WIDTH - BALL-WIDTH], 0.0] else s6-ball-x-moved;
        s6-ball-y-next = if (s6-right-hit) then max[min[s6-ball-y-moved, HEIGHT - BALL-HEIGHT], 0.0] else s6-ball-y-moved;
        s6-paddle-yl = if (s6-left-score | s6-right-score) then reset-paddle-y else s6-paddle-yl-clipped;
        s6-paddle-yr = if (s6-left-score | s6-right-score) then reset-paddle-y else s6-paddle-yr-clipped;
        s6-ball-x = if (s6-left-score | s6-right-score) then reset-ball-x else s6-ball-x-next;
        s6-ball-y = if (s6-left-score | s6-right-score) then reset-ball-y else s6-ball-y-next;
        s6-ball-vx = if (s6-left-score | s6-right-score) then BALL-INITIAL-SPEED-X else s6-ball-vx-next;
        s6-ball-vy = if (s6-left-score | s6-right-score) then BALL-INITIAL-SPEED-Y else s6-ball-vy-next;
        s6-step-reward = if (s5-point) then s5-step-reward else if (s6-left-score) then 1.0 else if (s6-right-score) then -1.0 else 0.0;

        s7-active = ~s6-point;
        s7-opp-delta-raw = s6-ball-y - (s6-paddle-yl + PADDLE-HEIGHT / 2.0);
        s7-opp-delta = max[min[s7-opp-delta-raw, PADDLE-SPEED], -PADDLE-SPEED];
        s7-paddle-yr-pre = if (s7-active) then (s6-paddle-yr + PADDLE-SPEED * paddle-dir) else s6-paddle-yr;
        s7-paddle-yl-pre = if (s7-active) then (s6-paddle-yl + s7-opp-delta) else s6-paddle-yl;
        s7-paddle-yr-clipped = max[min[s7-paddle-yr-pre, max-paddle-y], min-paddle-y];
        s7-paddle-yl-clipped = max[min[s7-paddle-yl-pre, max-paddle-y], min-paddle-y];
        s7-ball-x-moved = if (s7-active) then (s6-ball-x + s6-ball-vx) else s6-ball-x;
        s7-ball-y-moved = if (s7-active) then (s6-ball-y + s6-ball-vy) else s6-ball-y;
        s7-top-bottom-bounce = s7-active & (s7-ball-y-moved < 0.0 | s7-ball-y-moved + BALL-HEIGHT > HEIGHT);
        s7-ball-vy-wall = if (s7-top-bottom-bounce) then -s6-ball-vy else s6-ball-vy;
        s7-left-hit = s7-active & (s7-ball-x-moved < 0.0) & (s7-ball-y-moved + BALL-HEIGHT > s7-paddle-yl-clipped) & (s7-ball-y-moved < s7-paddle-yl-clipped + PADDLE-HEIGHT);
        s7-left-score = s7-active & (s7-ball-x-moved < 0.0) & ~s7-left-hit;
        s7-right-region = s7-active & (s7-ball-x-moved + BALL-WIDTH > WIDTH);
        s7-right-hit = s7-right-region & (s7-ball-y-moved + BALL-HEIGHT > s7-paddle-yr-clipped) & (s7-ball-y-moved < s7-paddle-yr-clipped + PADDLE-HEIGHT);
        s7-right-score = s7-right-region & ~s7-right-hit;
        s7-point = s6-point | s7-left-score | s7-right-score;
        s7-score-l = if (s6-point) then s6-score-l else if (s7-right-score) then (s6-score-l + 1) else s6-score-l;
        s7-score-r = if (s6-point) then s6-score-r else if (s7-left-score) then (s6-score-r + 1) else s6-score-r;
        s7-match-terminal = (s7-score-l == MAX-SCORE) | (s7-score-r == MAX-SCORE);
        s7-ball-vx-next = if (s7-left-hit | s7-right-hit) then -s6-ball-vx else s6-ball-vx;
        s7-ball-vy-preclamp = if (s7-right-hit) then (s7-ball-vy-wall + BALL-SPEED-Y-INCREMENT * paddle-dir) else s7-ball-vy-wall;
        s7-ball-vy-next = if (s7-right-hit) then (if (abs[s7-ball-vy-preclamp] < 0.01) then BALL-SPEED-Y-INCREMENT else max[min[s7-ball-vy-preclamp, BALL-MAX-SPEED-Y], -BALL-MAX-SPEED-Y]) else s7-ball-vy-preclamp;
        s7-ball-x-next = if (s7-right-hit) then max[min[s7-ball-x-moved, WIDTH - BALL-WIDTH], 0.0] else s7-ball-x-moved;
        s7-ball-y-next = if (s7-right-hit) then max[min[s7-ball-y-moved, HEIGHT - BALL-HEIGHT], 0.0] else s7-ball-y-moved;
        s7-paddle-yl = if (s7-left-score | s7-right-score) then reset-paddle-y else s7-paddle-yl-clipped;
        s7-paddle-yr = if (s7-left-score | s7-right-score) then reset-paddle-y else s7-paddle-yr-clipped;
        s7-ball-x = if (s7-left-score | s7-right-score) then reset-ball-x else s7-ball-x-next;
        s7-ball-y = if (s7-left-score | s7-right-score) then reset-ball-y else s7-ball-y-next;
        s7-ball-vx = if (s7-left-score | s7-right-score) then BALL-INITIAL-SPEED-X else s7-ball-vx-next;
        s7-ball-vy = if (s7-left-score | s7-right-score) then BALL-INITIAL-SPEED-Y else s7-ball-vy-next;
        s7-step-reward = if (s6-point) then s6-step-reward else if (s7-left-score) then 1.0 else if (s7-right-score) then -1.0 else 0.0;

        s8-active = ~s7-point;
        s8-opp-delta-raw = s7-ball-y - (s7-paddle-yl + PADDLE-HEIGHT / 2.0);
        s8-opp-delta = max[min[s8-opp-delta-raw, PADDLE-SPEED], -PADDLE-SPEED];
        s8-paddle-yr-pre = if (s8-active) then (s7-paddle-yr + PADDLE-SPEED * paddle-dir) else s7-paddle-yr;
        s8-paddle-yl-pre = if (s8-active) then (s7-paddle-yl + s8-opp-delta) else s7-paddle-yl;
        s8-paddle-yr-clipped = max[min[s8-paddle-yr-pre, max-paddle-y], min-paddle-y];
        s8-paddle-yl-clipped = max[min[s8-paddle-yl-pre, max-paddle-y], min-paddle-y];
        s8-ball-x-moved = if (s8-active) then (s7-ball-x + s7-ball-vx) else s7-ball-x;
        s8-ball-y-moved = if (s8-active) then (s7-ball-y + s7-ball-vy) else s7-ball-y;
        s8-top-bottom-bounce = s8-active & (s8-ball-y-moved < 0.0 | s8-ball-y-moved + BALL-HEIGHT > HEIGHT);
        s8-ball-vy-wall = if (s8-top-bottom-bounce) then -s7-ball-vy else s7-ball-vy;
        s8-left-hit = s8-active & (s8-ball-x-moved < 0.0) & (s8-ball-y-moved + BALL-HEIGHT > s8-paddle-yl-clipped) & (s8-ball-y-moved < s8-paddle-yl-clipped + PADDLE-HEIGHT);
        s8-left-score = s8-active & (s8-ball-x-moved < 0.0) & ~s8-left-hit;
        s8-right-region = s8-active & (s8-ball-x-moved + BALL-WIDTH > WIDTH);
        s8-right-hit = s8-right-region & (s8-ball-y-moved + BALL-HEIGHT > s8-paddle-yr-clipped) & (s8-ball-y-moved < s8-paddle-yr-clipped + PADDLE-HEIGHT);
        s8-right-score = s8-right-region & ~s8-right-hit;
        s8-point = s7-point | s8-left-score | s8-right-score;
        s8-score-l = if (s7-point) then s7-score-l else if (s8-right-score) then (s7-score-l + 1) else s7-score-l;
        s8-score-r = if (s7-point) then s7-score-r else if (s8-left-score) then (s7-score-r + 1) else s7-score-r;
        s8-match-terminal = (s8-score-l == MAX-SCORE) | (s8-score-r == MAX-SCORE);
        s8-ball-vx-next = if (s8-left-hit | s8-right-hit) then -s7-ball-vx else s7-ball-vx;
        s8-ball-vy-preclamp = if (s8-right-hit) then (s8-ball-vy-wall + BALL-SPEED-Y-INCREMENT * paddle-dir) else s8-ball-vy-wall;
        s8-ball-vy-next = if (s8-right-hit) then (if (abs[s8-ball-vy-preclamp] < 0.01) then BALL-SPEED-Y-INCREMENT else max[min[s8-ball-vy-preclamp, BALL-MAX-SPEED-Y], -BALL-MAX-SPEED-Y]) else s8-ball-vy-preclamp;
        s8-ball-x-next = if (s8-right-hit) then max[min[s8-ball-x-moved, WIDTH - BALL-WIDTH], 0.0] else s8-ball-x-moved;
        s8-ball-y-next = if (s8-right-hit) then max[min[s8-ball-y-moved, HEIGHT - BALL-HEIGHT], 0.0] else s8-ball-y-moved;
        s8-paddle-yl = if (s8-left-score | s8-right-score) then reset-paddle-y else s8-paddle-yl-clipped;
        s8-paddle-yr = if (s8-left-score | s8-right-score) then reset-paddle-y else s8-paddle-yr-clipped;
        s8-ball-x = if (s8-left-score | s8-right-score) then reset-ball-x else s8-ball-x-next;
        s8-ball-y = if (s8-left-score | s8-right-score) then reset-ball-y else s8-ball-y-next;
        s8-ball-vx = if (s8-left-score | s8-right-score) then BALL-INITIAL-SPEED-X else s8-ball-vx-next;
        s8-ball-vy = if (s8-left-score | s8-right-score) then BALL-INITIAL-SPEED-Y else s8-ball-vy-next;
        s8-step-reward = if (s7-point) then s7-step-reward else if (s8-left-score) then 1.0 else if (s8-right-score) then -1.0 else 0.0;

        paddle-yl' = s8-paddle-yl;
        paddle-yr' = s8-paddle-yr;
        ball-x' = s8-ball-x;
        ball-y' = s8-ball-y;
        ball-vx' = s8-ball-vx;
        ball-vy' = s8-ball-vy;
        score-l' = s8-score-l;
        score-r' = s8-score-r;

        obs-paddle-yl = (s8-paddle-yl - min-paddle-y) / (max-paddle-y - min-paddle-y);
        obs-paddle-yr = (s8-paddle-yr - min-paddle-y) / (max-paddle-y - min-paddle-y);
        obs-ball-x = s8-ball-x / WIDTH;
        obs-ball-y = s8-ball-y / HEIGHT;
        obs-ball-vx = (s8-ball-vx + BALL-INITIAL-SPEED-X) / (2.0 * BALL-INITIAL-SPEED-X);
        obs-ball-vy = (s8-ball-vy + BALL-MAX-SPEED-Y) / (2.0 * BALL-MAX-SPEED-Y);
        obs-score-l = s8-score-l / MAX-SCORE;
        obs-score-r = s8-score-r / MAX-SCORE;
    };

    reward = s8-step-reward;

    termination {
        s8-match-terminal;
    };

    action-preconditions {
        move >= 0;
        move <= 2;
    };
}
